# ⚙️ 기본 설정 (Default Values)
DB_URL=jdbc:mariadb://poticard-db/poticard
DB_USER=root
DB_PASS=qwer1234
JWT_EXPIRE=1800000
JWT_SECRET=examplejwtsecretpleaseignoreitmustbechangedbeforeitshardrelease
UPLOAD_PATH=C:/example

# ✨ 부가 기능 설정 (Optional)
# 특정 기능을 사용하려면 해당 API 키 및 정보가 필요합니다.

# ☁️ AWS S3 업로드
AWS_BUCKET_NAME=example
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key

# 📧 이메일 인증
MAIL_ADDR=example@gmail.com
MAIL_PASS=exam exam exam exam

# 🤖 AI 첨삭 (Gemini)
GEMINI_API=your_gemini_api_key

# 💳 결제 (PortOne)
PORTONE_SECRET=your_portone_secret

# 🔐 소셜 로그인 (OAuth 2.0)
AES_KEY=your_aes_encryption_key
# Kakao
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_secret
KAKAO_REDIRECT_URI=http://example.com/login/oauth2/code/kakao
# Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_secret
GOOGLE_REDIRECT_URI=http://example.com/login/oauth2/code/google

# 📊 모니터링 (Jaeger)
JAEGER_URL=http://your_jaeger_ip:4318/v1/traces